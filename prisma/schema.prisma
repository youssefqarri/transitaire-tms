// Transitaire TMS - Schema Prisma
// Plateforme de gestion de transit douanier (Maroc)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH & USERS
// ============================================================

enum UserRole {
  ADMIN
  EXPLOITATION
  DECLARANT
  COMMIS_DOUANE
  BUREAU
  COMPTABILITE
  CLIENT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  image         String?
  password      String?   // hashed (credentials provider)
  role          UserRole  @default(EXPLOITATION)
  active        Boolean   @default(true)
  phone         String?

  // si role = CLIENT, relié à un Client (le compte porte le portail)
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  accounts          Account[]
  sessions          Session[]
  apiTokens         ApiToken[]
  emailAccounts     EmailAccount[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  dossierComments   DossierComment[]
  statusChanges     DossierStatusChange[]
  uploadedDocs      Document[]            @relation("UploadedBy")
  expectedDocumentsRequested ExpectedDocument[] @relation("ExpectedDocumentsRequested")
  createdDossiers   Dossier[]             @relation("CreatedBy")
  assignedDossiers  Dossier[]             @relation("AssignedTo")
  invoicesCreated   Invoice[]             @relation("InvoicesCreated")
  messagesSent      OutgoingMessage[]     @relation("MessagesSent")
  settingsUpdates   AppSetting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([clientId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Token d'accès API (pour intégrations externes, ex: Claude)
model ApiToken {
  id          String    @id @default(cuid())
  label       String                          // étiquette (ex: "Claude - Karim")
  tokenHash   String    @unique               // hash bcrypt du token
  prefix      String                          // 8 premiers chars du token (affichage)
  userId      String                          // hérite des permissions de cet user
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// CLIENTS & SUPPLIERS
// ============================================================

model Client {
  id           String   @id @default(cuid())
  name         String
  code         String?  @unique   // code client interne
  ice          String?  // identifiant commun de l'entreprise (Maroc)
  rc           String?  // registre de commerce
  taxId        String?  // identifiant fiscal
  email        String?
  phone        String?
  address      String?
  city         String?
  contactName  String?
  notes        String?  @db.Text
  active       Boolean  @default(true)

  dossiers Dossier[]
  users    User[]   // utilisateurs portail client
  invoices Invoice[]
  outgoingMessages OutgoingMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  country     String?
  email       String?
  phone       String?
  address     String?
  notes       String?  @db.Text

  dossiers Dossier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ============================================================
// DOSSIERS
// ============================================================

enum DossierType {
  IMPORT
  EXPORT
}

enum PaymentMode {
  WITH_PAYMENT      // avec paiement (engagement d'importation obligatoire)
  WITHOUT_PAYMENT   // sans paiement
}

enum PackagingUnit {
  COLIS
  PALETTES
  CONTENEURS
  REMORQUES
}

enum DossierStatus {
  OUVERTURE                       // ouverture dossier
  RECEPTIONNE                     // réceptionné
  DOCUMENTS_MANQUANTS             // documents manquants
  DOCUMENTS_RECUS                 // réception des documents manquants
  BON_A_DELIVRER_RECU             // réception bon à délivrer
  DECLARATION_EN_COURS            // déclaration en cours
  VALIDATION_DOUANE               // validation en douane
  VISITE                          // date de visite
  CONFORME                        // conforme (sans visite)
  BUREAU_VALEUR                   // soumis au bureau de valeur
  DEMANDE_DOCUMENTS               // demande de documents douane / MCI
  INSTANCE_FICHE_LIQUIDATION      // en instance de fiche de liquidation
  LIQUIDE                         // liquidé
  BON_A_ENLEVER_RESERVE           // bon à enlever sous réserve
  MAIN_LEVEE_RESERVE_CONFORMITE   // main levée sous réserve de conformité
  MAIN_LEVEE_RESERVE_DOCUMENTS    // main levée sous réserve de production des documents
  VALIDATION_MCA                  // validation MCA
  BON_A_ENLEVER                   // bon à enlever (générique)
  BON_A_ENLEVER_DEFINITIF         // bon à enlever définitif
  LIVRAISON                       // livraison en cours
  FACTURATION                     // facturation en cours
  FACTURE                         // facturé (émis au client)
  CLOTURE                         // dossier clôturé
  ANNULE                          // annulé (via WinApp externe)
}

model Dossier {
  id            String        @id @default(cuid())
  number        String        @unique          // numéro fourni par WinApp
  reference     String?                        // référence fournisseur (objet mail)
  type          DossierType   @default(IMPORT)
  paymentMode   PaymentMode   @default(WITH_PAYMENT)
  status        DossierStatus @default(OUVERTURE)

  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])

  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // marchandise
  goodsValue       Decimal? @db.Decimal(14, 2)
  goodsCurrency    String?  @default("EUR")
  goodsWeight      Decimal? @db.Decimal(12, 3)  // en kg
  goodsPackages    Int?     // quantité
  goodsPackagingUnit PackagingUnit @default(COLIS)
  goodsDescription String?  @db.Text

  // dates clés
  receivedAt           DateTime?  // date de réception du dossier
  docsCompleteAt       DateTime?
  bonADelivrerAt       DateTime?
  declarationAt        DateTime?
  visitDate                    DateTime?  // visite douane prévue
  visitEffectiveDate           DateTime?  // visite douane effective
  conformityVisitDate          DateTime?  // visite MCI prévue
  conformityVisitEffectiveDate DateTime?  // visite MCI effective
  liquidationAt                DateTime?
  deliveredAt                  DateTime?  // date de livraison
  closedAt                     DateTime?

  // contrôle
  controlOffice   String?      // bureau de contrôle (bureau douanier)
  // organisme de contrôle de conformité (1 seul) : Bureau Veritas, SGS, Applus (A+), TÜV Rheinland
  controlOrganism String?
  // services réglementaires sectoriels selon le produit : ONSSA, ANRT, IMANOR, DMP (0..N)
  regulatoryServices String[]  @default([])
  hasVisit        Boolean      @default(false)
  hasConformityVisit Boolean    @default(false)
  hasBureauValeur Boolean      @default(false)

  // drapeaux parallèles (cases à cocher multiples)
  billed                       Boolean @default(false)
  delivered                    Boolean @default(false)
  baeUnderPayment              Boolean @default(false)
  baeUnderConformity           Boolean @default(false)
  awaitingConformityValidation Boolean @default(false)
  customNote                   String? @db.Text

  // staff
  createdById   String?
  createdBy     User?    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedToId  String?
  assignedTo    User?    @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  // relations
  dums            DUM[]
  documents       Document[]
  expectedDocuments ExpectedDocument[]
  statusChanges   DossierStatusChange[]
  comments        DossierComment[]
  emails          EmailLink[]
  notifications   Notification[]
  invoiceItems    InvoiceItem[]
  outgoingMessages OutgoingMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([reference])
  @@index([number])
}

model DossierStatusChange {
  id          String        @id @default(cuid())
  dossierId   String
  dossier     Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  fromStatus  DossierStatus?
  toStatus    DossierStatus
  note        String?       @db.Text
  changedById String?
  changedBy   User?         @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@index([dossierId])
}

model DossierComment {
  id        String   @id @default(cuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  // commentaire interne ou visible au portail client
  internal  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([dossierId])
}

// ============================================================
// DUM (Déclaration Unique de Marchandise)
// ============================================================

enum DUMStatus {
  DRAFT
  ENREGISTRE       // enregistré dans BADR
  VALIDE
  LIQUIDE
  CLOTURE
}

model DUM {
  id          String     @id @default(cuid())
  number      String     @unique          // numéro DUM officiel
  dossierId   String
  dossier     Dossier    @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  status      DUMStatus  @default(DRAFT)
  bureau      String?    // bureau douane
  regime      String?    // régime douanier de la DUM (un dossier peut cumuler 2 régimes via 2 DUM)
  registeredAt DateTime?
  liquidatedAt DateTime?
  notes       String?    @db.Text

  // une DUM peut référencer plusieurs documents
  documents   Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dossierId])
  @@index([number])
}

// ============================================================
// DOCUMENTS
// ============================================================

// catégorie standardisée — détectable pour "documents manquants"
enum DocumentCategory {
  FACTURE_COMMERCIALE
  FACTURE_ORIGINALE
  COLISAGE
  FACTURE_FRET
  CONNAISSEMENT          // BL
  LTA_ORIGINALE          // Lettre de Transport Aérien
  CMR                    // Convention Marchandises Route
  DMP                    // Déclaration mode paiement
  ENGAGEMENT_IMPORTATION
  BON_A_DELIVRER
  CERTIFICAT_ORIGINE
  ASSURANCE
  LICENCE
  CERTIFICAT_SANITAIRE
  CERTIFICAT_PHYTOSANITAIRE
  CERTIFICAT_CONFORMITE
  ATTESTATION_POIDS_MESURE
  ATTESTATION_STOCKAGE
  CATALOGUE
  FICHE_LIQUIDATION
  TICKET_PAIEMENT
  BON_A_ENLEVER
  MAIN_LEVEE_RESERVE_PAIEMENT
  DEMANDE_SERVICE_MCI
  DEMANDE_SERVICE_PORTNET
  MESSAGE_PORTNET
  MESSAGE_DOUANE
  MESSAGE_CONFORMITE
  AUTRE
}

// Documents qu'un déclarant identifie comme manquants à demander au client.
// Indépendant des documents obligatoires standards. Visible par tous les rôles internes.
model ExpectedDocument {
  id            String           @id @default(cuid())
  dossierId     String
  dossier       Dossier          @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  category      DocumentCategory
  name          String?          // nom libre, ex: "Certificat halal", "Licence import"
  note          String?          @db.Text
  fulfilledAt   DateTime?        // marqué comme reçu manuellement (sans upload)

  requestedById String?
  requestedBy   User?            @relation("ExpectedDocumentsRequested", fields: [requestedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dossierId])
}

model Document {
  id          String           @id @default(cuid())
  dossierId   String
  dossier     Dossier          @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  dumId       String?
  dum         DUM?             @relation(fields: [dumId], references: [id], onDelete: SetNull)
  category    DocumentCategory
  name        String
  fileUrl     String?          // chemin local ou S3
  fileSize    Int?
  mimeType    String?
  version     Int              @default(1)
  // si version > 1, remplace un document précédent
  replacesId  String?          @unique
  replaces    Document?        @relation("DocumentVersions", fields: [replacesId], references: [id], onDelete: SetNull)
  replacedBy  Document?        @relation("DocumentVersions")

  uploadedById String?
  uploadedBy   User?    @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  receivedAt DateTime @default(now())
  notes      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dossierId, category])
}

// ============================================================
// EMAILS
// ============================================================

enum EmailSource {
  DOUANE
  PORTNET
  MCI
  CLIENT
  COMPAGNIE_MARITIME
  INTERNE
  AUTRE
}

enum EmailDirection {
  INCOMING
  OUTGOING
}

model EmailAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   @default("gmail")  // gmail, outlook, imap
  emailAddress  String
  accessToken   String?  @db.Text
  refreshToken  String?  @db.Text
  tokenExpiresAt DateTime?
  historyId     String?  // dernier history Gmail synced
  active        Boolean  @default(true)

  messages EmailMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([emailAddress])
}

model EmailMessage {
  id           String         @id @default(cuid())
  accountId    String
  account      EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId   String         // gmail id
  threadId     String?
  direction    EmailDirection @default(INCOMING)
  fromAddress  String
  fromName     String?
  toAddresses  String[]       // array
  cc           String[]
  subject      String?
  snippet      String?        @db.Text
  bodyText     String?        @db.Text
  bodyHtml     String?        @db.Text
  receivedAt   DateTime
  source       EmailSource    @default(AUTRE)
  // classification IA
  category     String?
  isRead       Boolean        @default(false)
  isImportant  Boolean        @default(false)

  attachments EmailAttachment[]
  links       EmailLink[]

  createdAt DateTime @default(now())

  @@unique([accountId, externalId])
  @@index([receivedAt])
  @@index([source])
}

model EmailAttachment {
  id         String        @id @default(cuid())
  messageId  String
  message    EmailMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String?
  size       Int?
  fileUrl    String?

  createdAt DateTime @default(now())
}

// lien email <-> dossier (auto par DUM number ou reference)
model EmailLink {
  id        String        @id @default(cuid())
  messageId String
  message   EmailMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  dossierId String
  dossier   Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  // automatique ou manuel
  auto      Boolean       @default(true)
  matchedOn String?       // "DUM:1234567" ou "REF:ABC"

  createdAt DateTime @default(now())

  @@unique([messageId, dossierId])
  @@index([dossierId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

enum NotificationKind {
  DOCUMENT_MANQUANT
  DOSSIER_BLOQUE
  ACTION_URGENTE_DOUANE
  DEMANDE_INSPECTEUR
  DEMANDE_MCI
  SUIVI_LIQUIDATION
  STATUS_CHANGE
  EMAIL_NEW
  CLIENT_INFO          // notification à envoyer au client
  CLIENT_DOC_UPLOAD    // le client a déposé un document via le portail
  CLIENT_NEW_DOSSIER   // le client a ouvert un nouveau dossier via le portail
  AUTRE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // ou diffusion à un rôle
  role      UserRole?
  dossierId String?
  dossier   Dossier?         @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?
  read      Boolean          @default(false)
  // envoyé au client par mail ?
  emailSent Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([role, read])
}

// ============================================================
// AUDIT LOG
// ============================================================

// ============================================================
// FACTURATION (Honoraires + Débours)
// ============================================================

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  CANCELLED
  OVERDUE
}

enum InvoiceItemKind {
  HONORAIRE       // honoraires soumis à TVA (20% au Maroc)
  DEBOURS         // débours sans TVA (avance de frais douane, fret, etc.)
  AUTRE
}

enum PaymentMethod {
  VIREMENT
  CHEQUE
  ESPECES
  CMI
  TRAITE
  AUTRE
}

model Invoice {
  id            String         @id @default(cuid())
  number        String         @unique           // ex: F-2026-0001
  year          Int                              // pour numérotation annuelle
  sequence      Int                              // séquence dans l'année

  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])

  status        InvoiceStatus  @default(DRAFT)

  issuedAt      DateTime?
  dueAt         DateTime?
  paidAt        DateTime?
  paidAmount    Decimal        @default(0) @db.Decimal(12, 2)

  notes         String?        @db.Text
  termsOfPayment String?
  paymentMethod PaymentMethod?
  paymentRef    String?

  items         InvoiceItem[]

  createdById   String?
  createdBy     User?          @relation("InvoicesCreated", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([year, sequence])
  @@index([clientId, status])
  @@index([status])
}

model InvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  kind        InvoiceItemKind @default(HONORAIRE)
  description String
  quantity    Decimal         @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal         @db.Decimal(12, 2)
  vatRate     Decimal         @default(20) @db.Decimal(5, 2)
  dossierId   String?
  dossier     Dossier?        @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  order       Int             @default(0)

  @@index([invoiceId])
  @@index([dossierId])
}

// ============================================================
// TEMPLATES DE MESSAGES (Email + WhatsApp)
// ============================================================

enum MessageChannel {
  EMAIL
  WHATSAPP
}

enum MessageLang {
  FR
  AR
  EN
}

model MessageTemplate {
  id        String          @id @default(cuid())
  key       String                                // ex: "docs_manquants", "bae_pret", "fiche_liquidation"
  channel   MessageChannel
  lang      MessageLang     @default(FR)
  subject   String?                               // email uniquement
  body      String          @db.Text              // peut contenir {{client.name}}, {{dossier.number}}, etc.
  active    Boolean         @default(true)
  notes     String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, channel, lang])
}

model OutgoingMessage {
  id          String         @id @default(cuid())
  channel     MessageChannel
  lang        MessageLang
  templateKey String?
  toAddress   String                             // email ou +212XXXXXXXXX
  subject     String?
  body        String         @db.Text
  status      String         @default("PENDING") // PENDING, SENT, FAILED, DELIVERED, READ
  error       String?        @db.Text
  externalId  String?                            // ID Meta/SMTP

  dossierId   String?
  dossier     Dossier?       @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  clientId    String?
  client      Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sentById    String?
  sentBy      User?          @relation("MessagesSent", fields: [sentById], references: [id], onDelete: SetNull)

  sentAt      DateTime?
  createdAt   DateTime       @default(now())

  @@index([dossierId])
  @@index([clientId])
  @@index([channel, status])
}

// ============================================================
// PARAMÈTRES APPLICATION (singleton, id=1)
// ============================================================

// Les valeurs ici prennent le pas sur celles de .env.
// Permet à l'admin de configurer SMTP/S3 depuis l'interface
// sans toucher au .env / sans redéploiement.
model AppSetting {
  id              Int      @id @default(1)

  // ─── SMTP (emails sortants vers clients) ─────────────────
  smtpHost        String?
  smtpPort        Int?     @default(587)
  smtpUser        String?
  smtpPass        String?      // ⚠ stocké en clair — DB Supabase privée
  smtpFrom        String?
  smtpSecure      Boolean      @default(false)

  // ─── Stockage fichiers ───────────────────────────────────
  storageDriver   String   @default("local")     // "local" | "s3"
  s3Endpoint      String?
  s3Region        String?
  s3Bucket        String?
  s3AccessKeyId   String?
  s3SecretKey     String?      // ⚠ stocké en clair
  s3PublicBaseUrl String?

  updatedAt       DateTime @updatedAt
  updatedById     String?
  updatedBy       User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // CREATE_DOSSIER, UPDATE_STATUS, ...
  entity    String   // Dossier, DUM, Document, ...
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}
