# Copier en .env et renseigner. Voir docs/SELF-HOSTING.md.

# Base de données PostgreSQL
DATABASE_URL=postgresql://tms:CHANGE_ME@postgres:5432/transitaire_tms
# (Docker compose) mot de passe du service postgres
POSTGRES_PASSWORD=CHANGE_ME

# Authentification (NextAuth) — openssl rand -base64 32
AUTH_SECRET=CHANGE_ME
AUTH_URL=https://tms.votre-domaine.ma
NEXT_PUBLIC_APP_URL=https://tms.votre-domaine.ma

# Chiffrement des secrets en base (optionnel mais recommandé) — openssl rand -base64 32
ENCRYPTION_KEY=

# Stockage des pièces jointes : "local" ou "s3"
STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads

# Email sortant (SMTP) — optionnel, configurable aussi via /parametres
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# Stockage S3 (si STORAGE_DRIVER=s3) — optionnel, configurable aussi via /parametres
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# OAuth Gmail (si envoi via Gmail API) — optionnel
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
